{
  "name": "marie-v1",
  "version": "1.0.0",
  "type": "module",
  "license": "BSD-3-Clause",
  "private": true,
  "bin": {
    "marie": "./src/index.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node scripts/bootstrap.js",
    "dev": "pnpm --filter @marie/app dev",
    "build": "pnpm -r build",
    "lock": "node scripts/lock-to-go.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3",
      "sharp"
    ],
    "overrides": {
      "tough-cookie": "^4.1.3",
      "psl": "1.8.0"
    },
    "packageExtensions": {
      "psl@*": {
        "dependencies": {
          "punycode": "^2.3.1"
        }
      }
    }
  },
  "dependencies": {
    "@marie/brain": "workspace:*",
    "@marie/fca": "workspace:*",
    "@marie/memory": "workspace:*",
    "@marie/skills": "workspace:*",
    "@marie/tg": "workspace:*",
    "fs-extra": "^11.3.4"
  },
  "devDependencies": {}
}
